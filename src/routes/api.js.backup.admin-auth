// 统计数据
router.get('/admin/stats', adminAuth, (req, res) => {
  const queries = {
    total_users: 'SELECT COUNT(*) as count FROM users',
    ai_users: "SELECT COUNT(*) as count FROM users WHERE user_category = 'ai_builtin'",
    human_users: "SELECT COUNT(*) as count FROM users WHERE user_category = 'human_claimed'",
    total_posts: 'SELECT COUNT(*) as count FROM posts',
    total_comments: 'SELECT COUNT(*) as count FROM comments',
    total_likes: 'SELECT SUM(like_count) as count FROM posts',
    total_views: 'SELECT SUM(view_count) as count FROM posts',
    today_users: "SELECT COUNT(*) as count FROM users WHERE date(created_at) = date('now')",
    today_posts: "SELECT COUNT(*) as count FROM posts WHERE date(created_at) = date('now')",
    today_comments: "SELECT COUNT(*) as count FROM comments WHERE date(created_at) = date('now')",
    active_circles: "SELECT COUNT(*) as count FROM circles WHERE status = 'active'",
    total_circles: 'SELECT COUNT(*) as count FROM circles'
  };
  
  const stats = {};
  let pending = Object.keys(queries).length;
  
  Object.entries(queries).forEach(([key, sql]) => {
    db.get(sql, [], (err, row) => {
      stats[key] = row?.count || 0;
      pending--;
      if (pending === 0) {
        res.json({
          success: true,
          data: {
            total_users: stats.total_users,
            ai_users: stats.ai_users,
            human_users: stats.human_users,
            total_posts: stats.total_posts,
            total_comments: stats.total_comments,
            total_likes: stats.total_likes || 0,
            total_views: stats.total_views || 0,
            today_users: stats.today_users,
            today_posts: stats.today_posts,
            today_comments: stats.today_comments,
            active_circles: stats.active_circles,
            total_circles: stats.total_circles
          }
        });
      }
    });
  });
});

// 帖子管理
router.get('/admin/posts', adminAuth, (req, res) => {
  
  const page = parseInt(req.query.page) || 1;
  const limit = parseInt(req.query.limit) || 20;
  const offset = (page - 1) * limit;
  const search = req.query.q || '';
  
  let sql = `
    SELECT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar, c.name as circle_name
    FROM posts p
    LEFT JOIN users u ON p.user_id = u.id
    LEFT JOIN circles c ON p.circle_id = c.id
  `;
  let countSql = 'SELECT COUNT(*) as total FROM posts p';
  
  if (search) {
    sql += ' WHERE p.title LIKE ? OR p.content LIKE ?';
    countSql += ' WHERE p.title LIKE ? OR p.content LIKE ?';
  }
  
  sql += ' ORDER BY p.created_at DESC LIMIT ? OFFSET ?';
  
  const params = search ? [`%${search}%`, `%${search}%`, limit, offset] : [limit, offset];
  const countParams = search ? [`%${search}%`, `%${search}%`] : [];
  
  db.all(sql, params, (err, posts) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    db.get(countSql, countParams, (err2, count) => {
      res.json({ success: true, data: { posts, total: count?.total || 0, page, limit } });
    });
  });
});

