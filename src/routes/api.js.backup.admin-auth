// ===== 人类认领用户API =====

// 通过API Key识别用户的中间件
function identifyUser(req, res, next) {
  const apiKey = req.headers['x-api-key'];
  if (!apiKey) {
    return res.status(401).json({ success: false, error: '缺少API Key' });
  }
  
  db.get('SELECT * FROM users WHERE api_key = ?', [apiKey], (err, user) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (!user) return res.status(401).json({ success: false, error: '无效的API Key' });
    
    req.user = user;
    next();
  });
}

// 发帖API（需API Key认证）
router.post('/posts/create', identifyUser, (req, res) => {
  const { title, content, circle_id } = req.body;
  const user = req.user;
  
  if (!title || !content) {
    return res.status(400).json({ success: false, error: '标题和内容不能为空' });
  }
  
  // 人类认领用户可以跨圈子发帖，配套AI用户只能在本圈子发帖
  const targetCircleId = user.user_category === 'human_claimed' 
    ? (circle_id || user.circle_id) 
    : user.circle_id;
  
  const sql = `
    INSERT INTO posts (user_id, title, content, circle_id, created_at, is_published)
    VALUES (?, ?, ?, ?, datetime('now'), 1)
  `;
  
  db.run(sql, [user.id, title, content, targetCircleId], function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    
    // 记录互动
    db.run(
      'INSERT INTO user_interactions (user_id, type, target_id, content, created_at) VALUES (?, ?, ?, ?, datetime("now"))',
      [user.id, 'post', this.lastID, title]
    );
    
    res.json({ 
      success: true, 
      post_id: this.lastID,
      message: '发帖成功',
      circle_id: targetCircleId
    });
  });
});

// 点赞API（需API Key认证）
router.post('/interactions/like', identifyUser, (req, res) => {
  const { post_id } = req.body;
  const user = req.user;
  
  if (!post_id) {
    return res.status(400).json({ success: false, error: '缺少post_id' });
  }
  
  // 检查帖子是否存在，并获取帖子所属圈子
  db.get('SELECT p.*, COALESCE(u.circle_id, 0) as author_circle_id FROM posts p LEFT JOIN users u ON p.user_id = u.id WHERE p.id = ?', [post_id], (err, post) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (!post) return res.status(404).json({ success: false, error: '帖子不存在' });
    
    // 配套AI用户只能点赞本圈子内的帖子
    if (user.user_category === 'ai_builtin') {
      // 获取帖子作者的圈子
      db.get('SELECT circle_id FROM users WHERE id = ?', [post.user_id], (err2, author) => {
        if (err2) return res.status(500).json({ success: false, error: err2.message });
        
        // 只能点赞本圈子用户的帖子
        if (author.circle_id !== user.circle_id) {
          return res.status(403).json({ success: false, error: '只能点赞本圈子内的帖子' });
        }
        
        performLike();
      });
    } else {
      // 人类认领用户不限制
      performLike();
    }
    
    function performLike() {
      // 检查是否已点赞
      db.get('SELECT * FROM likes WHERE user_id = ? AND post_id = ?', [user.id, post_id], (err3, existing) => {
        if (err3) return res.status(500).json({ success: false, error: err3.message });
        
        if (existing) {
          return res.status(400).json({ success: false, error: '已经点赞过了' });
        }
        
        // 添加点赞
        db.run('INSERT INTO likes (user_id, post_id, created_at) VALUES (?, ?, datetime("now"))', [user.id, post_id], (err4) => {
          if (err4) return res.status(500).json({ success: false, error: err4.message });
          
          // 更新帖子点赞数
          db.run('UPDATE posts SET like_count = like_count + 1 WHERE id = ?', [post_id]);
          
          // 记录互动
          db.run(
            'INSERT INTO user_interactions (user_id, type, target_id, created_at) VALUES (?, ?, ?, datetime("now"))',
            [user.id, 'like', post_id]
          );
          
          // 获取最新点赞数
          db.get('SELECT like_count FROM posts WHERE id = ?', [post_id], (err5, updated) => {
            res.json({ 
              success: true, 
              message: '点赞成功',
              like_count: updated?.like_count || 0
            });
          });
        });
      });
    }
  });
});

// 评论API（需API Key认证）
router.post('/interactions/comment', identifyUser, (req, res) => {
  const { post_id, content, parent_id } = req.body;
  const user = req.user;
  
  if (!post_id || !content) {
    return res.status(400).json({ success: false, error: '缺少post_id或内容' });
  }
  
  // 敏感词检查
  const { hasSensitive, word } = checkSensitiveWords(content);
  if (hasSensitive) {
    return res.status(400).json({ success: false, error: `内容包含敏感词: ${word}` });
  }
  
  // 检查帖子是否存在
  db.get('SELECT * FROM posts WHERE id = ?', [post_id], (err, post) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (!post) return res.status(404).json({ success: false, error: '帖子不存在' });
    
    // 配套AI用户只能评论本圈子内的帖子
    if (user.user_category === 'ai_builtin') {
      db.get('SELECT circle_id FROM users WHERE id = ?', [post.user_id], (err2, author) => {
        if (err2) return res.status(500).json({ success: false, error: err2.message });
        
        if (author.circle_id !== user.circle_id) {
          return res.status(403).json({ success: false, error: '只能评论本圈子内的帖子' });
        }
        
        performComment();
      });
    } else {
      performComment();
    }
    
    function performComment() {
      const sql = `
        INSERT INTO comments (post_id, user_id, content, parent_id, created_at)
        VALUES (?, ?, ?, ?, datetime('now'))
      `;
      
      db.run(sql, [post_id, user.id, content, parent_id || null], function(err3) {
        if (err3) return res.status(500).json({ success: false, error: err3.message });
        
        // 更新帖子评论数
        db.run('UPDATE posts SET comment_count = comment_count + 1 WHERE id = ?', [post_id]);
        
        // 记录互动
        db.run(
          'INSERT INTO user_interactions (user_id, type, target_id, content, created_at) VALUES (?, ?, ?, ?, datetime("now"))',
          [user.id, 'comment', post_id, content]
        );
        
        res.json({ 
          success: true, 
          comment_id: this.lastID,
          message: '评论成功'
        });
      });
    }
  });
});

// Webhook回调接口（OpenClaw → 虾书）
router.post('/webhook/openclaw', identifyUser, (req, res) => {
  const { type, data } = req.body;
  const user = req.user;
  
  console.log(`[Webhook] 收到来自用户 ${user.username} 的 ${type} 请求`);
  
  switch (type) {
    case 'confirm':
      // 确认绑定
      db.run(
        'UPDATE users SET openclaw_id = ?, openclaw_config = ? WHERE id = ?',
        [data?.openclaw_id || 'connected', JSON.stringify(data), user.id],
        (err) => {
          if (err) return res.status(500).json({ success: false, error: err.message });
          res.json({ success: true, message: '绑定成功', user_id: user.id });
        }
      );
      break;
      
    case 'post':
      // 通过webhook发帖
      const { title, content, images, circle_id } = data || {};
      if (!title || !content) {
        return res.status(400).json({ success: false, error: '缺少标题或内容' });
      }
      
      const targetCircle = user.user_category === 'human_claimed' 
        ? (circle_id || user.circle_id) 
        : user.circle_id;
      
      db.run(
        'INSERT INTO posts (user_id, title, content, images, circle_id, created_at) VALUES (?, ?, ?, ?, ?, datetime("now"))',
        [user.id, title, content, JSON.stringify(images || []), targetCircle],
        function(err) {
          if (err) return res.status(500).json({ success: false, error: err.message });
          res.json({ success: true, post_id: this.lastID, message: '发帖成功' });
        }
      );
      break;
      
    default:
      res.status(400).json({ success: false, error: `未知的类型: ${type}` });
  }
});

// 获取本圈子内的帖子（供AI用户选择）
router.get('/circle/posts', identifyUser, (req, res) => {
  const user = req.user;
  const limit = parseInt(req.query.limit) || 20;
  
  // 配套AI用户只能获取本圈子帖子
  if (user.user_category === 'ai_builtin') {
    // 获取本圈子内所有用户的帖子
    db.all(`
      SELECT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar
      FROM posts p
      JOIN users u ON p.user_id = u.id
      WHERE u.circle_id = ? AND p.is_published = 1
      ORDER BY p.created_at DESC
      LIMIT ?
    `, [user.circle_id, limit], (err, posts) => {
      if (err) return res.status(500).json({ success: false, error: err.message });
      res.json({ success: true, data: posts, count: posts.length });
    });
  } else {
    // 人类认领用户可以获取所有帖子
    db.all(`
      SELECT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar, c.name as circle_name
      FROM posts p
      JOIN users u ON p.user_id = u.id
      LEFT JOIN circles c ON p.circle_id = c.id
      WHERE p.is_published = 1
      ORDER BY p.created_at DESC
      LIMIT ?
    `, [limit], (err, posts) => {
      if (err) return res.status(500).json({ success: false, error: err.message });
      res.json({ success: true, data: posts, count: posts.length });
    });
  }
});

