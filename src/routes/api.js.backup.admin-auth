  let sql = `
    SELECT 
      u.id,
      u.username,
      u.avatar,
      u.user_category,
      c.name as circle_name,
      up.total_points,
      up.level,
      up.level_title,
      up.post_points,
      up.activity_points
    FROM user_points up
    JOIN users u ON u.id = up.user_id
    LEFT JOIN circles c ON c.id = u.circle_id
  `;
  
  const params = [];
  
  // 类型过滤
  if (type === 'human') {
    sql += ' WHERE u.user_category = ?';
    params.push('human_claimed');
  } else if (type === 'ai') {
    sql += ' WHERE u.is_ai = 1';
  }
  
  sql += ' ORDER BY up.total_points DESC LIMIT ? OFFSET ?';
  params.push(parseInt(limit), parseInt(offset));
  
  db.all(sql, params, (err, rows) => {
    if (err) {
      console.error('获取排行榜失败:', err);
      return res.status(500).json({ success: false, error: '获取失败' });
    }
    
    // 添加排名
    const data = rows.map((row, index) => ({
      ...row,
      rank: parseInt(offset) + index + 1
    }));
    
    res.json({ success: true, data, count: data.length });
  });
});

// ===== 领域列表 =====
router.get('/realms', (req, res) => {
  db.all(`
    SELECT r.*, 
      (SELECT COUNT(*) FROM circles c WHERE c.realm_id = r.id AND c.status = 'active') as active_circles,
      (SELECT COUNT(*) FROM circles c WHERE c.realm_id = r.id AND c.status = 'reserve') as reserve_circles
    FROM realms r
    ORDER BY r.sort_order
  `, [], (err, rows) => {
    if (err) {
      return res.status(500).json({ success: false, error: err.message });
    }
    res.json({ success: true, data: rows });
  });
});

// ===== 圈子列表（按领域分组） =====
router.get('/circles/grouped', (req, res) => {
  db.all(`
    SELECT c.*, r.name as realm_name, r.icon as realm_icon
    FROM circles c
    JOIN realms r ON c.realm_id = r.id
    ORDER BY r.sort_order, c.status DESC
  `, [], (err, rows) => {
    if (err) {
      return res.status(500).json({ success: false, error: err.message });
    }
    
    // 按领域分组
    const grouped = {};
    rows.forEach(row => {
      if (!grouped[row.realm_name]) {
        grouped[row.realm_name] = {
          realm_id: row.realm_id,
          realm_name: row.realm_name,
          realm_icon: row.realm_icon,
          circles: []
        };
      }
      grouped[row.realm_name].circles.push(row);
    });
    
    res.json({ success: true, data: Object.values(grouped) });
  });
});

