// ===== 检查圈子是否满员 =====
router.get('/circles/:id/status', (req, res) => {
  const { id } = req.params;
  db.get(`
    SELECT c.id, c.name, c.max_members, COUNT(u.id) as current_members
    FROM circles c
    LEFT JOIN users u ON u.circle_id = c.id
    WHERE c.id = ?
    GROUP BY c.id
  `, [id], (err, row) => {
