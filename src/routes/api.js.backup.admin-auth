// ===== 管理后台 - 用户完整档案 =====
router.get('/admin/users/:id/full', adminAuth, (req, res) => {
  const userId = req.params.id;
  
  // 获取用户基本信息
  db.get(`
    SELECT u.*, c.name as circle_name, up.level_title
    FROM users u
    LEFT JOIN circles c ON u.circle_id = c.id
    LEFT JOIN user_points up ON up.user_id = u.id
    WHERE u.id = ?
  `, [userId], (err, user) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (!user) return res.status(404).json({ success: false, error: '用户不存在' });
    
    // 获取用户帖子
    db.all(`
      SELECT id, title, category, like_count, comment_count, created_at
      FROM posts WHERE user_id = ? ORDER BY created_at DESC LIMIT 10
    `, [userId], (err, posts) => {
      if (err) posts = [];
      
      // 获取用户评论
      db.all(`
        SELECT c.id, c.post_id, c.content, c.created_at, p.title as post_title
        FROM comments c
        LEFT JOIN posts p ON c.post_id = p.id
        WHERE c.user_id = ? ORDER BY c.created_at DESC LIMIT 10
      `, [userId], (err, comments) => {
        if (err) comments = [];
        
        // 获取最近行为
        db.all(`
          SELECT type, target_id, content, created_at
          FROM user_interactions WHERE user_id = ? ORDER BY created_at DESC LIMIT 20
        `, [userId], (err, activities) => {
          if (err) activities = [];
          
          res.json({
            success: true,
            data: {
              // 基本信息
              id: user.id,
              username: user.username,
              email: user.email,
              user_category: user.user_category,
              circle_id: user.circle_id,
              circle_name: user.circle_name,
              api_key: user.api_key,
              social_platform: user.social_platform,
              social_account: user.social_account,
              points: user.points,
              level: user.level,
              level_title: user.level_title,
              created_at: user.created_at,
              last_login_at: user.last_login_at,
              
              // 行为统计
              stats: {
                total_posts: user.total_posts || 0,
                total_likes_given: user.total_likes_given || 0,
                total_comments: user.total_comments || 0,
                total_views: user.total_views || 0
              },
              
              // 最近行为
              recent_activities: activities,
              
              // 发帖列表
              posts: posts,
              
              // 评论列表
              comments: comments
            }
          });
        });
      });
    });
  });
});

// ===== 管理后台 - 创建用户 =====
router.post('/admin/users', (req, res) => {
  const { username, email, circle_id, user_category = 'ai_builtin', social_platform, social_account } = req.body;
  
  if (!username || !email) {
    return res.status(400).json({ success: false, error: '用户名和邮箱不能为空' });
  }
  
  // 生成API Key
  const apiKey = 'XB_' + crypto.randomBytes(8).toString('hex').toUpperCase();
  const passwordHash = crypto.createHash('sha256').update('default123' + 'xiabook_salt').digest('hex');
  
  db.run(`
    INSERT INTO users (username, email, password_hash, circle_id, user_category, api_key, social_platform, social_account, created_at)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, datetime('now'))
  `, [username, email, passwordHash, circle_id, user_category, apiKey, social_platform, social_account], function(err) {
    if (err) {
      if (err.message.includes('UNIQUE')) {
        return res.status(400).json({ success: false, error: '用户名或邮箱已存在' });
      }
      return res.status(500).json({ success: false, error: err.message });
    }
    res.json({ success: true, data: { id: this.lastID, api_key: apiKey } });
  });
});

// ===== 管理后台 - 更新用户 =====
router.put('/admin/users/:id', (req, res) => {
  const userId = req.params.id;
  const { username, email, circle_id, social_platform, social_account, points, level } = req.body;
  
  const updates = [];
  const params = [];
  
  if (username) { updates.push('username = ?'); params.push(username); }
  if (email) { updates.push('email = ?'); params.push(email); }
  if (circle_id !== undefined) { updates.push('circle_id = ?'); params.push(circle_id); }
  if (social_platform !== undefined) { updates.push('social_platform = ?'); params.push(social_platform); }
  if (social_account !== undefined) { updates.push('social_account = ?'); params.push(social_account); }
  if (points !== undefined) { updates.push('points = ?'); params.push(points); }
  if (level !== undefined) { updates.push('level = ?'); params.push(level); }
  
  if (updates.length === 0) {
    return res.status(400).json({ success: false, error: '没有要更新的字段' });
  }
  
  params.push(userId);
  
  db.run(`UPDATE users SET ${updates.join(', ')} WHERE id = ?`, params, function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (this.changes === 0) return res.status(404).json({ success: false, error: '用户不存在' });
    res.json({ success: true });
  });
});

// ===== 管理后台 - 删除用户（软删除）=====
router.delete('/admin/users/:id', (req, res) => {
  const userId = req.params.id;
  
  // 不允许删除admin用户
  if (parseInt(userId) === 1) {
    return res.status(403).json({ success: false, error: '不能删除admin用户' });
  }
  
  // 软删除：标记为deleted，设置删除时间
  db.run(`
    UPDATE users 
    SET status = 'deleted', 
        deleted_at = datetime('now'),
        api_key = NULL
    WHERE id = ?
  `, [userId], function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (this.changes === 0) return res.status(404).json({ success: false, error: '用户不存在' });
    
    // 记录审计日志
    db.run(`
      INSERT INTO audit_logs (action, target_type, target_id, operator, details, created_at)
      VALUES ('delete_user', 'user', ?, 'admin', ?, datetime('now'))
    `, [userId, JSON.stringify({ reason: '用户注销' })]);
    
    res.json({ success: true, message: '用户已注销，30天后永久删除' });
  });
});

// ===== 管理后台 - 获取用户行为数据 =====
router.get('/admin/claimed-users/:id/behaviors', adminAuth, (req, res) => {
  const { id } = req.params;
  
  // 获取行为统计
  db.get(`
    SELECT 
      COUNT(DISTINCT date(created_at)) as active_days,
      COUNT(CASE WHEN action = 'view' THEN 1 END) as total_views,
      COUNT(CASE WHEN action = 'like' THEN 1 END) as total_likes_given,
      COUNT(CASE WHEN action = 'comment' THEN 1 END) as total_comments,
      COUNT(CASE WHEN action = 'post' THEN 1 END) as total_posts
    FROM user_behaviors 
    WHERE user_id = ?
  `, [id], (err, stats) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    
    // 获取最近行为
    db.all(`
      SELECT action, target_type, created_at
      FROM user_behaviors 
      WHERE user_id = ?
      ORDER BY created_at DESC
      LIMIT 10
    `, [id], (err, recentActions) => {
      res.json({
        success: true,
        data: {
          active_days: stats?.active_days || 0,
          total_views: stats?.total_views || 0,
          total_likes_given: stats?.total_likes_given || 0,
          recent_actions: recentActions || []
        }
      });
    });
  });
});

// ===== 管理后台 - 重置API Key =====
router.post('/admin/users/:id/reset-apikey', (req, res) => {
  const userId = req.params.id;
  const newApiKey = 'XB_' + crypto.randomBytes(8).toString('hex').toUpperCase();
  
  db.run('UPDATE users SET api_key = ? WHERE id = ?', [newApiKey, userId], function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (this.changes === 0) return res.status(404).json({ success: false, error: '用户不存在' });
    res.json({ success: true, data: { api_key: newApiKey } });
  });
});

// ===== 管理后台 - 批量更新用户圈子 =====
router.post('/admin/users/batch-circle', (req, res) => {
  const { user_ids, circle_id } = req.body;
  
  if (!user_ids || !Array.isArray(user_ids) || user_ids.length === 0) {
    return res.status(400).json({ success: false, error: '请选择要更新的用户' });
  }
  
  const placeholders = user_ids.map(() => '?').join(',');
  db.run(`UPDATE users SET circle_id = ? WHERE id IN (${placeholders})`, [circle_id, ...user_ids], function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    res.json({ success: true, updated: this.changes });
  });
});

// ===== 管理后台 - 创建圈子 =====
router.post('/admin/circles', (req, res) => {
  const { name, description, realm, icon, max_ai_users = 40, max_human_users = 10 } = req.body;
  
  if (!name) {
    return res.status(400).json({ success: false, error: '圈子名称不能为空' });
  }
  
  db.run(`
    INSERT INTO circles (name, description, realm, icon, max_ai_users, max_human_users, status, created_at)
    VALUES (?, ?, ?, ?, ?, ?, 'reserve', datetime('now'))
  `, [name, description, realm, icon, max_ai_users, max_human_users], function(err) {
    if (err) {
      if (err.message.includes('UNIQUE')) {
        return res.status(400).json({ success: false, error: '圈子名称已存在' });
      }
      return res.status(500).json({ success: false, error: err.message });
    }
    const circleId = this.lastID;
    
    // 为新圈子生成40个AI用户
    generateAIUsersForCircle(circleId, (err) => {
      if (err) console.error('生成AI用户失败:', err);
      console.log(`[圈子创建] ${name} 已创建，并生成40个AI用户`);
    });
    
    res.json({ success: true, data: { id: circleId, ai_users_created: 40 } });
  });
});

// ===== 管理后台 - 更新圈子 =====
router.put('/admin/circles/:id', (req, res) => {
  const circleId = req.params.id;
  const { name, description, icon, status, max_ai_users, max_human_users } = req.body;
  
  const updates = [];
  const params = [];
  
  if (name) { updates.push('name = ?'); params.push(name); }
  if (description !== undefined) { updates.push('description = ?'); params.push(description); }
  if (icon !== undefined) { updates.push('icon = ?'); params.push(icon); }
  if (status) { 
    updates.push('status = ?'); 
    params.push(status); 
  }
  if (max_ai_users !== undefined) { updates.push('max_ai_users = ?'); params.push(max_ai_users); }
  if (max_human_users !== undefined) { updates.push('max_human_users = ?'); params.push(max_human_users); }
  
  if (updates.length === 0) {
    return res.status(400).json({ success: false, error: '没有要更新的字段' });
  }
  
  params.push(circleId);
  
  db.run(`UPDATE circles SET ${updates.join(', ')} WHERE id = ?`, params, function(err) {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (this.changes === 0) return res.status(404).json({ success: false, error: '圈子不存在' });
    
    // 如果状态改为active，检查AI用户数量
    if (status === 'active') {
      db.get(`SELECT COUNT(*) as count FROM users WHERE circle_id = ? AND user_category = 'ai_builtin'`, [circleId], (err, row) => {
        if (err) return;
        const aiCount = row?.count || 0;
        if (aiCount < 40) {
          console.log(`[圈子激活] 圈子${circleId}只有${aiCount}个AI用户，补充到40个`);
          generateAIUsersForCircle(circleId);
        }
      });
    }
    
    res.json({ success: true });
  });
});

// ===== 管理后台 - 删除圈子 =====
router.delete('/admin/circles/:id', (req, res) => {
  const circleId = req.params.id;
  
  // 检查圈子是否有用户
  db.get('SELECT COUNT(*) as count FROM users WHERE circle_id = ?', [circleId], (err, row) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    
    if (row.count > 0) {
      return res.status(400).json({ success: false, error: '圈子内有用户，请先迁移用户' });
    }
    
    db.run('DELETE FROM circles WHERE id = ?', [circleId], function(err) {
      if (err) return res.status(500).json({ success: false, error: err.message });
      if (this.changes === 0) return res.status(404).json({ success: false, error: '圈子不存在' });
      res.json({ success: true });
    });
  });
});

