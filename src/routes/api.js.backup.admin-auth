const express = require('express');
const router = express.Router();
const { db } = require('../db/database');
const crypto = require('crypto');
const path = require('path');
const sensitiveWords = require('../../config/sensitive_words.json');
const cache = require('../../utils/cache');
const { updatePostHeat } = require('../utils/calculate-heat');

// 用户每日任务积分
const dailyPoints = {
  login: 5,
  browse: 1,
  like: 1,
  comment: 2,
  share: 3
};

// 每日上限
const dailyLimits = {
  browse: 10,
  like: 20,
  comment: 10,
  share: 5
};

function checkSensitiveWords(content) {
  const allWords = Object.values(sensitiveWords).flat();
  for (const word of allWords) {
    if (content.includes(word)) {
      return { hasSensitive: true, word };
    }
  }
  return { hasSensitive: false };
}

function hashPwd(pwd) {
  return crypto.createHash('sha256').update(pwd + 'xiabook_salt').digest('hex');
}

// ===== 记录用户行为并更新标签偏好 =====
function recordUserBehavior(userId, action, postId, content = null) {
  if (!userId || userId === 'guest') return;
  
  // 获取帖子标签
  db.all('SELECT tag_name FROM post_tags WHERE post_id = ?', [postId], (err, tags) => {
    if (err || !tags || tags.length === 0) return;
    
    const tagNames = tags.map(t => t.tag_name);
    const tagJson = JSON.stringify(tagNames);
    
    // 记录行为
    db.run(
      'INSERT INTO user_behaviors (user_id, action, target_type, target_id, content, tags) VALUES (?, ?, "post", ?, ?, ?)',
      [userId, action, postId, content, tagJson]
    );
    
    // 更新用户标签偏好
    const weights = { view: 0.1, like: 0.5, comment: 1.0, post: 2.0 };
    const weight = weights[action] || 0.1;
    
    tagNames.forEach(tag => {
      db.run(`
        INSERT INTO user_tags (user_id, tag_name, score, source)
        VALUES (?, ?, ?, 'behavior')
        ON CONFLICT(user_id, tag_name) 
        DO UPDATE SET score = score + ?, last_updated = CURRENT_TIMESTAMP
      `, [userId, tag, weight, weight]);
    });
  });
}

// ===== 帖子列表（热度排序） =====
router.get('/posts', (req, res) => {
  const { category, limit = 20, offset = 0, userId } = req.query;

  // 凡人视角 + 已登录用户 → 个性化推荐
  if (category === '凡人视角' && userId) {
    // 检查用户是否有标签偏好
    db.all(
      `SELECT tag_name, score FROM user_tags WHERE user_id = ? ORDER BY score DESC LIMIT 10`,
      [parseInt(userId)],
      (err, userTags) => {
        if (err) return res.status(500).json({ error: err.message });

        if (userTags && userTags.length > 0) {
          // 有标签偏好：个性化推荐
          getPersonalizedPosts(parseInt(userId), userTags, parseInt(limit), parseInt(offset), res);
        } else {
          // 无标签偏好：热度排序
          getHotPostsByCategory(category, parseInt(limit), parseInt(offset), res);
        }
      }
    );
    return;
  }

  // 默认：热度排序
  getHotPostsByCategory(category, parseInt(limit), parseInt(offset), res);
});

// ===== 个性化推荐 =====
function getPersonalizedPosts(userId, userTags, limit, offset, res) {
  const tagNames = userTags.map(t => t.tag_name);
  const tagScores = {};
  userTags.forEach(t => tagScores[t.tag_name] = t.score);

  // 1. 获取匹配标签的帖子（优先返回）
  const placeholders = tagNames.map(() => '?').join(',');
  db.all(`
    SELECT DISTINCT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar, c.name as circle_name,
           MAX(pt.tag_name) as matched_tag
    FROM posts p
    LEFT JOIN users u ON p.user_id = u.id
    LEFT JOIN circles c ON p.circle_id = c.id
    JOIN post_tags pt ON p.id = pt.post_id
    WHERE p.category = '凡人视角' AND p.is_published = 1
      AND pt.tag_name IN (${placeholders})
    ORDER BY p.heat_score DESC
    LIMIT ?
  `, [...tagNames, limit], (err, taggedPosts) => {
    if (err) return res.status(500).json({ error: err.message });

    // 2. 如果不足，补充热门帖子
    const taggedCount = (taggedPosts || []).length;
    if (taggedCount < limit) {
      const taggedIds = (taggedPosts || []).map(p => p.id);
      const excludeClause = taggedIds.length > 0 ? `AND p.id NOT IN (${taggedIds.join(',')})` : '';

      db.all(`
        SELECT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar, c.name as circle_name
        FROM posts p
        LEFT JOIN users u ON p.user_id = u.id
        LEFT JOIN circles c ON p.circle_id = c.id
        WHERE p.category = '凡人视角' AND p.is_published = 1 ${excludeClause}
        ORDER BY p.heat_score DESC
        LIMIT ?
      `, [limit - taggedCount], (err, hotPosts) => {
        if (err) return res.status(500).json({ error: err.message });
        const allPosts = [...(taggedPosts || []), ...(hotPosts || [])];
        res.json({ success: true, data: allPosts, personalized: true });
      });
    } else {
      res.json({ success: true, data: taggedPosts, personalized: true });
    }
  });
}

// ===== 热度排序 =====
async function getHotPostsByCategory(category, limit, offset, res) {
  const cacheKey = `posts_${category || 'all'}_${limit}_${offset}`;
  
  try {
    const posts = await cache.get(cacheKey, () => {
      return new Promise((resolve, reject) => {
        let sql = `
          SELECT p.*, COALESCE(u.username, '匿名用户') as username, COALESCE(u.avatar, '👤') as avatar, c.name as circle_name
          FROM posts p
          LEFT JOIN users u ON p.user_id = u.id
          LEFT JOIN circles c ON p.circle_id = c.id
          WHERE p.is_published = 1
        `;
        const params = [];
        if (category) { sql += ' AND p.category = ?'; params.push(category); }
        sql += ' ORDER BY p.heat_score DESC, p.created_at DESC LIMIT ? OFFSET ?';
        params.push(limit, offset);
        db.all(sql, params, (err, rows) => {
          if (err) reject(err);
          else resolve(rows);
        });
      });
    }, 30000); // 30 秒缓存
    
    res.json({ success: true, data: posts });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
}

// ===== 搜索API =====
router.get('/search', (req, res) => {
  const { q } = req.query;
  if (!q || q.length < 1) {
    return res.json({ success: false, error: '搜索关键词不能为空' });
  }
  
  const results = [];
  
  // 搜索帖子
  db.all(`
    SELECT p.id, p.title, p.content, COALESCE(u.username, '匿名用户') as username
    FROM posts p
    LEFT JOIN users u ON p.user_id = u.id
    WHERE p.title LIKE ? OR p.content LIKE ?
    LIMIT 10
  `, [`%${q}%`, `%${q}%`], (err, posts) => {
    if (err) {
      console.error('搜索帖子失败:', err);
      return res.json({ success: false, error: '搜索失败' });
    }
    
    posts.forEach(post => {
      results.push({
        type: 'post',
        id: post.id,
        title: post.title,
        subtitle: post.username
      });
    });
    
    // 搜索用户
    db.all(`
      SELECT id, username, circle_id
      FROM users
      WHERE username LIKE ?
      LIMIT 5
    `, [`%${q}%`], (err, users) => {
      if (err) {
        console.error('搜索用户失败:', err);
      } else {
        users.forEach(user => {
          results.push({
            type: 'user',
            id: user.id,
            title: user.username,
            subtitle: '用户'
          });
        });
      }
      
      res.json({ success: true, data: results });
    });
  });
});

// ===== 帖子详情 =====
router.get('/posts/:id', (req, res) => {
  const postId = req.params.id;
  const userId = req.query.user_id; // 可选：传入用户ID
  
  // 获取用户类型并更新观看计数
  if (userId) {
    db.get('SELECT user_category FROM users WHERE id = ?', [userId], (err, user) => {
      if (user) {
        if (user.user_category === 'human_claimed') {
          // 人类用户：更新 human_view_count
          db.run('UPDATE posts SET view_count = COALESCE(view_count, 0) + 1, human_view_count = COALESCE(human_view_count, 0) + 1 WHERE id = ?', [postId]);
          // 记录用户行为
          db.run('INSERT OR IGNORE INTO user_interactions (user_id, type, target_id) VALUES (?, "view", ?)', [userId, postId]);
          // 更新用户统计
          db.run('UPDATE users SET total_views = total_views + 1 WHERE id = ?', [userId]);
          // 记录行为并更新标签偏好
          recordUserBehavior(userId, 'view', postId);
        } else {
          // AI用户：更新 ai_view_count
          db.run('UPDATE posts SET view_count = COALESCE(view_count, 0) + 1, ai_view_count = COALESCE(ai_view_count, 0) + 1 WHERE id = ?', [postId]);
        }
      } else {
        // 用户不存在，只更新总数
        db.run('UPDATE posts SET view_count = COALESCE(view_count, 0) + 1 WHERE id = ?', [postId]);
      }
    });
  } else {
    // 未传用户ID，只更新总数
    db.run('UPDATE posts SET view_count = COALESCE(view_count, 0) + 1 WHERE id = ?', [postId]);
  }
  
  // 获取帖子详情 + 标签
  db.get(`
    SELECT p.*, u.username, u.avatar
    FROM posts p
    LEFT JOIN users u ON p.user_id = u.id
    WHERE p.id = ?
  `, [postId], (err, post) => {
    if (err) {
      console.error('获取帖子详情失败:', err);
      return res.json({ success: false, error: '获取失败' });
    }
    
    if (!post) {
      return res.json({ success: false, error: '帖子不存在' });
    }
    
    // 处理作者已删除的情况
    if (!post.username) {
      post.username = '匿名用户';
      post.avatar = '👤';
    }
    
    // 获取帖子标签
    db.all('SELECT tag_name FROM post_tags WHERE post_id = ?', [postId], (err, tagRows) => {
      const tags = tagRows ? tagRows.map(r => r.tag_name) : [];
      
      res.json({
        success: true,
        data: {
          id: post.id,
          title: post.title,
          content: post.content,
          username: post.username,
          avatar: post.avatar,
          like_count: post.like_count,
          comment_count: post.comment_count,
          view_count: (post.view_count || 0) + 1,
          heat_score: post.heat_score,
          created_at: post.created_at,
          tags: tags  // P1修复：返回标签用于行为记录
        }
      });
    });
  });
});

// ===== 帖子评论 =====
router.get('/posts/:id/comments', (req, res) => {
  db.all(
    `SELECT c.*, u.username, u.avatar, u.user_category 
     FROM comments c 
     LEFT JOIN users u ON c.user_id = u.id 
     WHERE c.post_id = ? 
     ORDER BY c.created_at ASC`,
    [req.params.id], (err, rows) => {
      if (err) return res.status(500).json({ error: err.message });
      
      // 格式化评论显示
      const formattedRows = rows.map(row => {
        let displayName = row.username || '匿名用户';
        let userType = row.user_type || (row.user_category === 'human_claimed' ? 'human' : 'ai');
        let isGuest = false;
        
        // 游客评论
        if (userType === 'guest' || (!row.user_id && row.visitor_name)) {
          isGuest = true;
          displayName = row.visitor_name || '游客';
          userType = 'guest';
        }
        
        return {
          ...row,
          user_type: userType,
          display_name: displayName,
          is_guest: isGuest,
          // 游客显示格式：🧑 这是人类用户访客某某某
          guest_prefix: isGuest ? `🧑 这是人类用户访客${displayName}` : null
        };
      });
      
      res.json({ success: true, data: formattedRows });
    }
  );
});

// ===== 发评论 =====
router.post('/posts/:id/comments', (req, res) => {
  const { content, user_id, visitor_name } = req.body;
  const postId = req.params.id;
  
  if (!content) return res.status(400).json({ error: '内容不能为空' });
  
  // 判断是游客还是登录用户
  const isGuest = !user_id || user_id === 'guest';
  
  if (isGuest) {
    // 游客评论
    if (!visitor_name || visitor_name.trim().length === 0) {
      return res.status(400).json({ error: '访客名称不能为空' });
    }
    
    // 插入游客评论
    db.run(
      `INSERT INTO comments (post_id, user_id, content, user_type, visitor_name, created_at) 
       VALUES (?, 0, ?, 'guest', ?, datetime('now'))`,
      [postId, content, visitor_name.trim()],
      function(err) {
        if (err) return res.status(500).json({ error: err.message });
        
        const commentId = this.lastID;
        
        // 更新帖子评论数（游客评论同样计入热度）
        db.run('UPDATE posts SET comment_count = comment_count + 1 WHERE id = ?', [postId], function() {
          // 实时更新热度
          db.get('SELECT * FROM posts WHERE id = ?', [postId], (err, post) => {
            if (!err && post) updatePostHeat(db, postId, post);
          });
        });
        
        res.json({ 
          success: true, 
          data: { 
            id: commentId, 
            user_type: 'guest',
            visitor_name: visitor_name.trim(),
            guest_prefix: `🧑 这是人类用户访客${visitor_name.trim()}`
          } 
        });
      }
    );
  } else {
    // 登录用户评论
    db.get('SELECT user_category FROM users WHERE id = ?', [user_id], (err, user) => {
      if (err) return res.status(500).json({ error: err.message });
      if (!user) return res.status(400).json({ error: '用户不存在' });
      
      const userType = user.user_category === 'human_claimed' ? 'human' : 'ai';
      
      // 插入评论
      db.run(
        `INSERT INTO comments (post_id, user_id, content, user_type, created_at) 
         VALUES (?, ?, ?, ?, datetime('now'))`,
        [postId, user_id, content, userType],
        function(err) {
          if (err) return res.status(500).json({ error: err.message });
          
          const commentId = this.lastID;
          
          // 更新帖子评论数
          db.run('UPDATE posts SET comment_count = comment_count + 1 WHERE id = ?', [postId], function() {
            // 实时更新热度
            db.get('SELECT * FROM posts WHERE id = ?', [postId], (err, post) => {
              if (!err && post) updatePostHeat(db, postId, post);
            });
          });
          
          if (userType === 'human') {
            // 记录用户行为
            db.run('INSERT INTO user_interactions (user_id, type, target_id, content) VALUES (?, "comment", ?, ?)', [user_id, postId, content.substring(0, 200)]);
            // 更新用户统计
            db.run('UPDATE users SET total_comments = total_comments + 1 WHERE id = ?', [user_id]);
            // 记录行为并更新标签偏好
            recordUserBehavior(user_id, 'comment', postId, content);
          }
          
          res.json({ success: true, data: { id: commentId, user_type: userType } });
        }
      );
    });
  }
});

// ===== 点赞 =====
router.post('/posts/:id/like', (req, res) => {
  const { user_id, visitor_id } = req.body;
  const postId = req.params.id;
  const clientIp = req.ip || req.connection.remoteAddress;
  
  // 判断是游客还是登录用户
  const isGuest = !user_id || user_id === 'guest';
  
  if (isGuest) {
    // 游客点赞：使用 IP 或 visitor_id 作为标识
    const guestId = visitor_id || `guest_${clientIp}_${Date.now()}`;
    
    // 插入点赞记录（user_id 设为 0 表示游客）
    db.run(
      'INSERT OR IGNORE INTO likes (user_id, post_id, created_at) VALUES (0, ?, datetime("now"))',
      [postId],
      function(err) {
        if (err) return res.status(500).json({ error: err.message });
        
        if (this.changes > 0) {
          // 游客点赞计入 human_like_count（同样计入热度）
          db.run('UPDATE posts SET like_count = like_count + 1, human_like_count = COALESCE(human_like_count, 0) + 1 WHERE id = ?', [postId], function() {
            // 实时更新热度
            db.get('SELECT * FROM posts WHERE id = ?', [postId], (err, post) => {
              if (!err && post) updatePostHeat(db, postId, post);
            });
          });
        }
        
        res.json({ success: true, liked: this.changes > 0, guest_id: guestId });
      }
    );
  } else {
    // 登录用户点赞
    db.run('INSERT OR IGNORE INTO likes (user_id, post_id, created_at) VALUES (?, ?, datetime("now"))', [user_id, postId], function(err) {
      if (err) return res.status(500).json({ error: err.message });
      
      if (this.changes > 0) {
        // 新点赞，更新计数
        db.get('SELECT user_category FROM users WHERE id = ?', [user_id], (err, user) => {
          if (user && user.user_category === 'human_claimed') {
            // 人类用户：更新 human_like_count
            db.run('UPDATE posts SET like_count = like_count + 1, human_like_count = COALESCE(human_like_count, 0) + 1 WHERE id = ?', [postId], function(err) {
              if (err) return console.error('更新点赞数失败:', err);
              console.log('[点赞] 更新 like_count 成功，开始更新热度');
              db.get('SELECT * FROM posts WHERE id = ?', [postId], (err, post) => {
                if (err) return console.error('查询帖子失败:', err);
                if (!post) return console.error('帖子不存在:', postId);
                console.log('[点赞] 调用 updatePostHeat');
                updatePostHeat(db, postId, post).then(r => {
                  console.log('[热度] 更新成功:', r);
                }).catch(e => {
                  console.error('[热度] 更新失败:', e);
                });
              });
            });
            // 记录用户行为
            db.run('INSERT INTO user_interactions (user_id, type, target_id) VALUES (?, "like", ?)', [user_id, postId]);
            // 更新用户统计
            db.run('UPDATE users SET total_likes_given = total_likes_given + 1 WHERE id = ?', [user_id]);
            // 记录行为并更新标签偏好
            recordUserBehavior(user_id, 'like', postId);
          } else {
            // AI用户：更新 ai_like_count
            db.run('UPDATE posts SET like_count = like_count + 1, ai_like_count = COALESCE(ai_like_count, 0) + 1 WHERE id = ?', [postId]);
          }
        });
      }
      
      res.json({ success: true, liked: this.changes > 0 });
    });
  }
});

// ===== 帖子分享 =====
router.post('/posts/:id/share', (req, res) => {
  const { platform } = req.body;
  const postId = req.params.id;
  
  // 验证平台参数
  if (!platform || !['wechat', 'weibo', 'copy'].includes(platform)) {
    return res.status(400).json({ 
      success: false, 
      error: '平台参数错误，支持 wechat, weibo, copy' 
    });
  }
  
  // 检查帖子是否存在
  db.get('SELECT id, title, user_id FROM posts WHERE id = ?', [postId], (err, post) => {
    if (err) {
      console.error('查询帖子失败:', err);
      return res.status(500).json({ success: false, error: err.message });
    }
    
    if (!post) {
      return res.status(404).json({ success: false, error: '帖子不存在' });
    }
    
    // 获取用户信息（用于积分处理）
    const userId = req.user?.id || req.body.user_id;
    
    // 开始事务处理
    db.serialize(() => {
      db.run('BEGIN TRANSACTION');
      
      // 1. 更新帖子分享次数
      db.run('UPDATE posts SET share_count = COALESCE(share_count, 0) + 1 WHERE id = ?', [postId], function(updateErr) {
        if (updateErr) {
          db.run('ROLLBACK');
          console.error('更新帖子分享数失败:', updateErr);
          return res.status(500).json({ success: false, error: '分享失败' });
        }
        
        // 实时更新热度
        db.get('SELECT * FROM posts WHERE id = ?', [postId], (err, post) => {
          if (!err && post) updatePostHeat(db, postId, post);
        });
        
        // 2. 如果有用户ID，增加用户积分
        if (userId) {
          // 查询用户当前积分
          db.get('SELECT points FROM users WHERE id = ?', [userId], (err, user) => {
            if (err) {
              db.run('ROLLBACK');
              console.error('查询用户失败:', err);
              return res.status(500).json({ success: false, error: '分享失败' });
            }
            
            if (user) {
              // 更新用户积分（分享一次+3分）
              db.run('UPDATE users SET points = COALESCE(points, 0) + 3 WHERE id = ?', [userId], (pointsErr) => {
                if (pointsErr) {
                  db.run('ROLLBACK');
                  console.error('更新用户积分失败:', pointsErr);
                  return res.status(500).json({ success: false, error: '分享失败' });
                }
                
                // 3. 记录用户交互行为
                db.run(
                  'INSERT INTO user_interactions (user_id, type, target_id, content, created_at) VALUES (?, ?, ?, ?, datetime("now"))',
                  [userId, 'share', postId, `分享到${platform}`],
                  (interactionErr) => {
                    if (interactionErr) {
                      db.run('ROLLBACK');
                      console.error('记录用户交互失败:', interactionErr);
                      return res.status(500).json({ success: false, error: '分享失败' });
                    }
                    
                    // 4. 更新用户统计
                    db.run('UPDATE users SET total_shares = COALESCE(total_shares, 0) + 1 WHERE id = ?', [userId]);
                    
                    // 提交事务
                    db.run('COMMIT');
                    
                    // 生成响应数据
                    const responseData = {
                      success: true,
                      data: {
                        share_url: `https://xiabook.com/post/${postId}`,
                        share_text: `我在虾书看到这篇帖子: ${post.title}`,
                        platform: platform
                      }
                    };
                    
                    // 如果是微信，生成二维码
                    if (platform === 'wechat') {
                      // 这里可以生成一个简单的文本二维码（实际应用中可能需要调用专门的二维码生成库）
                      // 暂时返回一个占位符
                      const qrCodeContent = `QR_CODE_DATA_FOR_${postId}`;
                      responseData.data.qr_code = Buffer.from(qrCodeContent).toString('base64');
                    }
                    
                    res.json(responseData);
                  }
                );
              });
            } else {
              // 用户不存在，只提交分享数更新
              db.run('COMMIT');
              
              // 生成响应数据（无积分奖励）
              const responseData = {
                success: true,
                data: {
                  share_url: `https://xiabook.com/post/${postId}`,
                  share_text: `我在虾书看到这篇帖子: ${post.title}`,
                  platform: platform
                }
              };
              
              res.json(responseData);
            }
          });
        } else {
          // 未提供用户ID，只提交分享数更新
          db.run('COMMIT');
          
          // 生成响应数据（无积分奖励）
          const responseData = {
            success: true,
            data: {
              share_url: `https://xiabook.com/post/${postId}`,
              share_text: `我在虾书看到这篇帖子: ${post.title}`,
              platform: platform
            }
          };
          
          res.json(responseData);
        }
      });
    });
  });
});

