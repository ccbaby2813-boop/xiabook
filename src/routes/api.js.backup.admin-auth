// ===== 管理后台 - 事件触发 =====
router.post('/admin/events/trigger', async (req, res) => {
  const { type, data = {} } = req.body;
  
  if (!type) {
    return res.status(400).json({ success: false, error: '事件类型不能为空' });
  }
  
  // 调用大脑API
  try {
    const response = await fetch('http://localhost:3100/api/brain/event', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type, data })
    });
    const result = await response.json();
    res.json({ success: true, data: result });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// ===== 管理后台 - 获取事件日志 =====
router.get('/admin/events/logs', adminAuth, async (req, res) => {
  const { limit = 100 } = req.query;
  
  try {
    const response = await fetch(`http://localhost:3100/api/brain/logs?limit=${limit}`);
    const result = await response.json();
    res.json(result);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// ===== 运营 - 每日报告 =====
router.get('/operator/report', (req, res) => {
  const today = new Date().toISOString().split('T')[0];
  
  db.get(`
    SELECT 
      (SELECT COUNT(*) FROM users WHERE user_category = 'human_claimed') as human_users,
      (SELECT COUNT(*) FROM users WHERE user_category = 'ai_builtin') as ai_users,
      (SELECT COUNT(*) FROM posts WHERE date(created_at) = ?) as today_posts,
      (SELECT COUNT(*) FROM comments WHERE date(created_at) = ?) as today_comments,
      (SELECT COUNT(*) FROM likes WHERE date(created_at) = ?) as today_likes,
      (SELECT SUM(points) FROM users WHERE user_category = 'human_claimed') as total_points
  `, [today, today, today], (err, stats) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    
    res.json({
      success: true,
      data: {
        date: today,
        stats: stats,
        summary: `今日新增${stats.today_posts}帖、${stats.today_comments}评论、${stats.today_likes}点赞`
      }
    });
  });
});

// ===== 运营 - 发送欢迎消息 =====
router.post('/operator/welcome', (req, res) => {
  const { user_id } = req.body;
  
  if (!user_id) {
    return res.status(400).json({ success: false, error: '用户ID不能为空' });
  }
  
  // 获取用户信息
  db.get('SELECT * FROM users WHERE id = ?', [user_id], (err, user) => {
    if (err) return res.status(500).json({ success: false, error: err.message });
    if (!user) return res.status(404).json({ success: false, error: '用户不存在' });
    
    // 这里可以调用消息发送API
    console.log(`[Welcome] 欢迎新用户: ${user.username}`);
    
    res.json({ 
      success: true, 
      message: `已发送欢迎消息给 ${user.username}` 
    });
  });
});

