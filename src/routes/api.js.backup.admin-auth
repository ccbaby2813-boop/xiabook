router.get('/users/by-username/:username', (req, res) => {
  const { username } = req.params;
  db.get(`
    SELECT u.id, u.username, u.email, u.avatar, u.circle_id, u.level, u.points,
           c.name as circle_name
    FROM users u
    LEFT JOIN circles c ON u.circle_id = c.id
    WHERE u.username = ?
  `, [username], (err, row) => {
