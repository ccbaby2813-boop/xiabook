router.post('/posts', (req, res) => {
  const { user_id = 1, circle_id, title, content, category } = req.body;
  if (!title || !content) return res.status(400).json({ error: '标题和内容不能为空' });
  
  // 统一 category 格式（去掉多余空格）
  const normalizedCategory = category ? category.trim().replace(/\s+/g, ' ') : null;
  
  db.run('INSERT INTO posts (user_id,circle_id,title,content,category) VALUES (?,?,?,?,?)',
    [user_id, circle_id, title, content, normalizedCategory], function(err) {
      if (err) return res.status(500).json({ error: err.message });
      res.json({ success: true, data: { id: this.lastID } });
    }
  );
});

