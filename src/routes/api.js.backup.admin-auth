// 后台管理员配置
const ADMIN_CONFIG = {
  username: 'ccbaby2813',
  password: 'Cc68414984',
  tokenExpire: 24 * 60 * 60 * 1000, // 24小时过期
  ipWhitelist: [
    '127.0.0.1',
    '::1',
    '::ffff:127.0.0.1',
    '172.19.57.244',
    '::ffff:172.19.57.244'
  ]
};

// 会话存储（内存）
const sessions = new Map();

// 操作日志
const adminLogs = [];

// 记录操作日志
function logAction(action, detail, req) {
  const log = {
    time: new Date().toISOString(),
    action,
    detail,
    ip: req.ip || req.connection.remoteAddress
  };
  adminLogs.push(log);
  if (adminLogs.length > 1000) adminLogs.shift();
  console.log('[Admin]', log.time, action, detail);
}

// 检查IP白名单（已关闭）
function checkIPWhitelist(req) {
  // 白名单已关闭，允许所有 IP 访问
  return true;
}

// 后台登录API
router.post('/admin/login', async (req, res) => {
  // 检查IP白名单
  if (!checkIPWhitelist(req)) {
    return res.status(403).json({ success: false, error: 'IP不在白名单中' });
  }
  
  const { username, password } = req.body;
  
  if (username === ADMIN_CONFIG.username && password === ADMIN_CONFIG.password) {
    // 生成token（包含过期时间）
    const expireAt = Date.now() + ADMIN_CONFIG.tokenExpire;
    const tokenData = `${username}:${expireAt}:${Math.random().toString(36).substr(2, 16)}`;
    const token = Buffer.from(tokenData).toString('base64');
    
    // 存储会话
    sessions.set(token, { username, expireAt, createdAt: Date.now() });
    
    // 记录登录日志
    logAction('login', `用户 ${username} 登录成功`, req);
    
    res.json({ 
      success: true, 
      token,
      expireAt: new Date(expireAt).toISOString(),
      message: '登录成功' 
    });
  } else {
    logAction('login_failed', `用户 ${username} 登录失败`, req);
    res.status(401).json({ success: false, error: '用户名或密码错误' });
  }
});

// 验证token中间件
function adminAuth(req, res, next) {
  const token = req.headers['x-admin-token'] || req.query.token;
  if (!token) {
    return res.status(401).json({ success: false, error: '未登录' });
  }
  
  // 检查会话
  const session = sessions.get(token);
  if (!session) {
    return res.status(401).json({ success: false, error: '会话不存在' });
  }
  
  // 检查过期
  if (Date.now() > session.expireAt) {
    sessions.delete(token);
    return res.status(401).json({ success: false, error: '会话已过期' });
  }
  
  // 记录请求
  req.adminSession = session;
  next();
}

