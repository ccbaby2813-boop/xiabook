/**
 * 后台管理认证中间件
 * 验证Bearer Token，确保只有管理员可以访问
 */

const ADMIN_CREDENTIALS = {
  username: 'ccbaby2813',
  password: 'Cc68414984'
};

/**
 * 生成Token
 * @param {string} username 
 * @returns {string} base64 encoded token
 */
function generateToken(username) {
  const expireTime = Date.now() + 24 * 60 * 60 * 1000; // 24小时有效
  const tokenData = `${username}:${expireTime}:${Math.random().toString(36).slice(2)}`;
  return Buffer.from(tokenData).toString('base64');
}

/**
 * 验证Token
 * @param {string} token 
 * @returns {object|null} { username, valid }
 */
function verifyToken(token) {
  if (!token) return null;
  
  try {
    const decoded = Buffer.from(token, 'base64').toString();
    const [username, expireTime] = decoded.split(':');
    
    // 检查是否过期
    if (Date.now() > parseInt(expireTime)) {
      return { valid: false, reason: 'Token已过期' };
    }
    
    // 检查用户名
    if (username !== ADMIN_CREDENTIALS.username) {
      return { valid: false, reason: '无效的用户' };
    }
    
    return { valid: true, username };
  } catch (e) {
    return { valid: false, reason: 'Token格式无效' };
  }
}

/**
 * 认证中间件
 */
function adminAuth(req, res, next) {
  // 从Header获取Token
  const authHeader = req.headers.authorization;
  let token = null;
  
  if (authHeader && authHeader.startsWith('Bearer ')) {
    token = authHeader.replace('Bearer ', '');
  }
  
  // 也可以从Query获取
  if (!token && req.query.token) {
    token = req.query.token;
  }
  
  // 验证Token
  const result = verifyToken(token);
  
  if (!result || !result.valid) {
    return res.status(401).json({
      success: false,
      error: result?.reason || '未登录'
    });
  }
  
  // 设置用户信息
  req.adminUser = result.username;
  next();
}

/**
 * 登录处理
 */
function handleLogin(req, res) {
  const { username, password } = req.body;
  
  if (!username || !password) {
    return res.status(400).json({
      success: false,
      error: '请输入用户名和密码'
    });
  }
  
  if (username !== ADMIN_CREDENTIALS.username || password !== ADMIN_CREDENTIALS.password) {
    return res.status(401).json({
      success: false,
      error: '用户名或密码错误'
    });
  }
  
  const token = generateToken(username);
  const expireTime = Date.now() + 24 * 60 * 60 * 1000;
  
  res.json({
    success: true,
    token,
    expireAt: new Date(expireTime).toISOString(),
    message: '登录成功'
  });
}

/**
 * 验证Token API
 */
function handleVerify(req, res) {
  res.json({
    success: true,
    data: {
      username: req.adminUser
    }
  });
}

module.exports = {
  adminAuth,
  handleLogin,
  handleVerify,
  generateToken,
  verifyToken,
  ADMIN_CREDENTIALS
};